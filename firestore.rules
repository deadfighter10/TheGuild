rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: read the authenticated user's rep from their user doc
    function getUserRep() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.repPoints;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Admin check: custom claims (primary), role field, or legacy repPoints -1 fallback
    function isAdminUser() {
      return request.auth.token.admin == true || getUserRole() == "admin" || getUserRep() == -1;
    }

    function isContributor() {
      return isAdminUser() || getUserRep() >= 100;
    }

    function isModerator() {
      return isAdminUser() || getUserRep() >= 3000;
    }

    // Users: anyone authenticated can read
    // Users can only create and update their own profile
    // repPoints and emailVerified can only be changed by Cloud Functions (Admin SDK)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.displayName.size() <= 50
        && (!('bio' in request.resource.data) || request.resource.data.bio.size() <= 500);
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.displayName.size() <= 50
        && (!('bio' in request.resource.data) || request.resource.data.bio.size() <= 500)
        // Prevent users from changing their own rep, role, emailVerified, or isSchoolEmail
        && request.resource.data.repPoints == resource.data.repPoints
        && request.resource.data.emailVerified == resource.data.emailVerified
        && request.resource.data.isSchoolEmail == resource.data.isSchoolEmail
        && request.resource.data.role == resource.data.role;
      // Delete only via Cloud Functions (Admin SDK bypasses rules)
      allow delete: if false;

      // Rep history: read own only, writes only via Admin SDK (Cloud Functions)
      match /repHistory/{eventId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // Advancements are readable by anyone authenticated, immutable
    match /advancements/{advancementId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Vouches: authenticated users can read, create with their own voucherId
    // Only contributors can vouch
    match /vouches/{vouchId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.voucherId == request.auth.uid
        && isContributor();
    }

    // Nodes (The Tree): authenticated users can read
    // Contributors can create their own nodes
    // Author or moderator can update
    // Delete only via Cloud Functions
    match /nodes/{nodeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && isContributor()
        && request.resource.data.title.size() <= 200
        && request.resource.data.description.size() <= 5000;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.authorId || isModerator());
      allow delete: if false;
    }

    // Node supports: authenticated users can read, contributors can create with own userId
    match /nodeSupports/{supportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && isContributor();
    }

    // Library entries: anyone authenticated can read
    // 1500+ Rep or admin can create
    // Author or moderator can update
    // Delete only via Cloud Functions
    match /libraryEntries/{entryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && (isAdminUser() || getUserRep() >= 1500)
        && request.resource.data.title.size() <= 200
        && request.resource.data.content.size() <= 50000;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.authorId || isModerator());
      allow delete: if false;
    }

    // Library entry versions: readable by authenticated, created alongside edits
    // S20 fix: require editedBy == auth.uid to prevent history pollution
    match /libraryEntryVersions/{versionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.editedBy == request.auth.uid;
      allow update, delete: if false;
    }

    // News links: authenticated can read
    // Contributors can create with own submitterId
    // Only submitter or moderator can update (score updates via votes)
    // Delete only via Cloud Functions
    match /newsLinks/{linkId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.submitterId == request.auth.uid
        && isContributor()
        && request.resource.data.title.size() <= 200
        && request.resource.data.url.size() <= 2000;
      // S17 fix: owner/moderator can fully update; contributors can only update score
      allow update: if request.auth != null
        && (
          (request.auth.uid == resource.data.submitterId || isModerator())
          || (isContributor()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['score']))
        );
      allow delete: if false;
    }

    // News votes: authenticated can read, contributors can create/update with own userId
    match /newsVotes/{voteId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && isContributor();
    }

    // Discussion threads: authenticated can read
    // Contributors can create with own authorId
    // Author or moderator can update/delete
    match /discussionThreads/{threadId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && isContributor()
        && request.resource.data.title.size() <= 200
        && request.resource.data.body.size() <= 10000;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.authorId || isModerator());
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.authorId || isModerator());
    }

    // Discussion replies: authenticated can read
    // Contributors can create with own authorId
    // Author or moderator can update/delete
    match /discussionReplies/{replyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && isContributor()
        && request.resource.data.body.size() <= 10000;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.authorId || isModerator())
        && request.resource.data.body.size() <= 10000;
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.authorId || isModerator());
    }

    // Audit log: append-only, admin-only (via custom claims or legacy rep)
    match /auditLog/{logId} {
      allow read: if request.auth != null && isAdminUser();
      allow create: if request.auth != null && isAdminUser();
    }

    // Notifications: users can only read/update their own, any authenticated user can create
    // S21 fix: validate type is a known enum, link starts with /
    match /notifications/{notifId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.message.size() <= 500
        && request.resource.data.type in ["reply", "support", "vouch", "flag", "rep_change", "status_change", "review"]
        && request.resource.data.link.matches('^/.*');
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Content flags (P0.3: Content Moderation)
    // Any authenticated user can flag content, one flag per user per target
    match /flags/{flagId} {
      allow read: if request.auth != null && (isModerator() || isAdminUser());
      allow create: if request.auth != null
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.reason.size() <= 1000;
      allow update: if request.auth != null && (isModerator() || isAdminUser());
      allow delete: if false;
    }

    // Bookmarks: users can CRUD their own bookmarks only
    match /bookmarks/{bookmarkId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.targetTitle.size() <= 200;
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // S16: Peer reviews — authenticated can read, contributors can create with own authorId
    // Contributors can update (claim review, submit feedback)
    match /peerReviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && isContributor();
      allow update: if request.auth != null
        && isContributor();
      allow delete: if false;
    }

    // S16: Achievements — authenticated can read, users can create their own only
    // Immutable once created (no update/delete)
    match /achievements/{achievementId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // S16: Spotlights — authenticated can read, contributors can create with own nominatedBy
    // Contributors can update (vote), no delete
    match /spotlights/{spotlightId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.nominatedBy == request.auth.uid
        && isContributor();
      allow update: if request.auth != null
        && isContributor();
      allow delete: if false;
    }

    // S18: Spotlight votes — dedup via composite ID {voterId}_{spotlightId}
    // Contributors can create with own voterId, one vote per spotlight
    match /spotlightVotes/{voteId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.voterId == request.auth.uid
        && isContributor();
      allow update, delete: if false;
    }

    // S16: Content collaborators — authenticated can read and create/delete
    // Immutable (no update)
    match /contentCollaborators/{collabId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
      allow update: if false;
    }

    // S16: Page views — anonymous create (privacy-first tracking)
    // Admin-only read, no update/delete
    match /pageViews/{viewId} {
      allow read: if request.auth != null && isAdminUser();
      allow create: if request.resource.data.path.size() <= 500;
      allow update, delete: if false;
    }

    // S7 Phase 2: Rate limit tracking docs
    // Each doc: rateLimits/{userId}_{collection} with lastWriteAt timestamp
    // Client must update this doc in a batch write alongside content creation
    // Rules enforce minimum 10-second interval between creates per collection
    match /rateLimits/{limitId} {
      allow read: if request.auth != null
        && limitId.matches(request.auth.uid + '_.*');
      allow create: if request.auth != null
        && limitId.matches(request.auth.uid + '_.*');
      allow update: if request.auth != null
        && limitId.matches(request.auth.uid + '_.*')
        && request.resource.data.lastWriteAt == request.time
        && (
          !exists(resource)
          || resource.data.lastWriteAt + duration.value(10, 's') < request.time
        );
      allow delete: if false;
    }
  }
}
