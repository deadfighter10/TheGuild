{
  "name": "the-guild",
  "version": "0.1.0",
  "description": "An open hub for contributors working on humanity's biggest scientific advancements",
  "type": "module",
  "license": "MIT",
  "author": "The Guild Contributors",
  "homepage": "https://github.com/deadfighter10/TheGuild",
  "repository": {
    "type": "git",
    "url": "https://github.com/deadfighter10/TheGuild.git"
  },
  "bugs": {
    "url": "https://github.com/deadfighter10/TheGuild/issues"
  },
  "keywords": [
    "open-science",
    "research",
    "collaboration",
    "react",
    "typescript",
    "firebase"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:local": "firebase emulators:exec --only auth,firestore \"vite\"",
    "emulators": "firebase emulators:start --only auth,firestore",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:rules": "vitest run --config vitest.rules.config.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "firebase": "^11.0.0",
    "fuse.js": "^7.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "three": "^0.183.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@happy-dom/global-registrator": "^20.8.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "happy-dom": "^20.8.3",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^2.1.0"
  }
}
